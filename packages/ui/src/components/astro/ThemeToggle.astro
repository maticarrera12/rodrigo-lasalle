---
const sunDots = [
	{ cx: 22, cy: 12, delay: 280 },
	{ cx: 19.0711, cy: 19.0711, delay: 200 },
	{ cx: 12, cy: 22, delay: 120 },
	{ cx: 4.9289, cy: 19.0711, delay: 40 },
	{ cx: 2, cy: 12, delay: 0 },
	{ cx: 4.9289, cy: 4.9289, delay: 80 },
	{ cx: 12, cy: 2, delay: 160 },
	{ cx: 19.0711, cy: 4.9289, delay: 240 },
] as const;
---

<button
	type="button"
	class="theme-toggle shrink-0 text-foreground hover:text-primary"
	data-theme-toggle
	aria-label="Activar modo oscuro"
>
	<svg
		width="1.25rem"
		height="1.25rem"
		viewBox="0 0 24 24"
		fill="none"
		class="theme-toggle__icon"
		aria-hidden="true"
	>
		<g class="theme-toggle__sun">
			{
				sunDots.map((dot) => (
					<circle
						class="theme-toggle__ray"
						cx={dot.cx}
						cy={dot.cy}
						r="1.5"
						fill="currentColor"
						style={`--ray-delay: ${dot.delay}ms`}
					/>
				))
			}
		</g>
		<circle
			class="theme-toggle__sun-body"
			cx="12"
			cy="12"
			stroke="currentColor"
			fill="none"
			r="6"
		/>
		<path
			class="theme-toggle__moon"
			d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			fill="none"
		/>
	</svg>
</button>
