---
interface Props {
	href: string;
	label?: string;
}

const { href, label = "Escribir por WhatsApp" } = Astro.props;
---

<a
	href={href}
	class="group inline-flex w-fit items-center gap-1.5 rounded-full bg-sobrio-3 px-6 py-3 text-sm font-light text-primary-foreground transition-all duration-100"
>
	{label}
	<svg
		xmlns="http://www.w3.org/2000/svg"
		viewBox="0 0 24 24"
		fill="none"
		class="h-4 w-4 shrink-0 transition-transform duration-200 group-hover:-translate-y-0.5"
		aria-hidden="true"
	>
		<path
			d="M7 17L17 7M17 7H9M17 7V15"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"></path>
	</svg>
</a>
