---
import { Icon } from "astro-icon/components";
import { AREAS } from "@/const";
---

<section id="especialidades" class="w-full py-8 lg:py-16">
	<div class="container pt-16 lg:pt-20">
		<div
			class="reveal mb-14 flex flex-col gap-8 lg:mb-16 lg:flex-row lg:items-end lg:justify-between lg:gap-16"
			data-reveal
		>
			<div class="max-w-md">
				<p class="text-xs font-medium uppercase tracking-[0.12em] text-calido-4">
					— 04 / Áreas de trabajo
				</p>
				<h1 class="pt-4 text-[clamp(3rem,4vw,2.75rem)] leading-tight text-calido-1 font-serif-ebgaramond">
					En qué <span class="text-calido-3 italic">te puedo</span> acompañar.
				</h1>
			</div>
			<p class="max-w-md text-lg leading-relaxed text-calido-4">
				Seis áreas que toco con frecuencia, explicadas como las explicaría en la primera consulta:
				qué problema resuelven, a quién le sirven, cuándo conviene venir antes de que todo se complique.
			</p>
		</div>

		<div class="divide-y divide-border border-y border-border">
			{
				AREAS.map((area, index) => (
					<article
						class="reveal group  flex flex-col gap-4 py-8 lg:grid lg:grid-cols-[4rem_minmax(0,16rem)_1fr_auto] lg:items-center lg:gap-x-8 lg:py-10"
						data-reveal
						data-reveal-delay={index * 60}
					>
						<div class="flex items-start justify-between gap-4 lg:contents">
							<p class="text-sm group-hover:translate-x-2 transition-all duration-200 tabular-nums text-calido-4">/ {area.n}</p>
							<div class="flex items-start gap-3 lg:col-start-2">
								<Icon name={area.icon} class="mt-1 h-5 w-5 shrink-0 text-calido-3 group-hover:translate-x-2 transition-all duration-200" aria-hidden="true" />
								<h2 class="text-2xl group-hover:translate-x-2 transition-all duration-200 leading-snug text-calido-1 font-serif-ebgaramond lg:text-[2rem]">
									{area.t}
								</h2>
							</div>
							<Icon
								name="mdi:arrow-right"
								class="h-5 w-5 shrink-0 text-calido-4 transition-all duration-200 group-hover:translate-x-2 group-hover:-rotate-45 group-hover:text-calido-3 lg:col-start-4"
								aria-hidden="true"
							/>
						</div>

						<p class="text-base group-hover:translate-x-2 transition-all duration-200 leading-relaxed text-calido-4 lg:col-start-3 lg:row-start-1">
							{area.d}
						</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.reveal {
		opacity: 0;
		transform: translateY(1rem);
		transition:
			opacity 0.55s ease,
			transform 0.55s ease;
	}

	.reveal.is-in {
		opacity: 1;
		transform: translateY(0);
	}
</style>

<script>
	import { initReveal } from "@/scripts/reveal";

	initReveal();
	document.addEventListener("astro:page-load", initReveal);
</script>
