---
import { HERO_STATS, MATRICULAS } from "@/const";
---

<div class="container border-t border-border py-12 lg:py-14">
	<div class="grid grid-cols-1 gap-10 sm:grid-cols-3 lg:gap-8">
		{
			HERO_STATS.map((stat) => (
				<div>
					<p class="text-xs font-medium uppercase tracking-[0.12em] text-calido-4">
						{stat.label}
					</p>
					<p class="pt-2 text-3xl text-calido-1 font-serif-ebgaramond lg:text-[2rem] lg:leading-tight">
						{stat.highlight}
					</p>
					<p class="pt-2 text-sm leading-relaxed text-calido-4">{stat.description}</p>
				</div>
			))
		}
	</div>

	<div
		class="mt-10 grid grid-cols-1 gap-10 border-t border-border pt-10 sm:grid-cols-3 lg:mt-12 lg:gap-8 lg:pt-12"
	>
		{
			MATRICULAS.map((matricula) => (
				<div>
					<p class="text-xs font-medium uppercase tracking-[0.12em] text-calido-4">
						{matricula.label}
					</p>
					<p class="pt-2 text-xl text-calido-1 font-serif-ebgaramond lg:text-2xl lg:leading-tight">
						{matricula.tomo}
					</p>
					<p class="pt-2 text-sm leading-relaxed text-calido-4">
						{matricula.description}
					</p>
				</div>
			))
		}
	</div>
</div>
