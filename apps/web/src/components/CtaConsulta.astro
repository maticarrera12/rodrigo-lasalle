---
import { buildWhatsappUrl } from "@/const";
import WhatsappButton from "@workspace/ui/components/astro/WhatsappButton.astro";

interface Props {
	eyebrow?: string;
	titleTop: string;
	titleAccent: string;
	text: string;
	whatsappMessage: string;
	whatsappLabel?: string;
}

const {
	eyebrow = "Hablemos de lo que necesitás",
	titleTop,
	titleAccent,
	text,
	whatsappMessage,
	whatsappLabel = "Agendar una consulta",
} = Astro.props;

const features = [
	{
		t: "Confidencialidad",
		d: "Tratamiento reservado de tu consulta desde el primer mensaje.",
		icon: "shield",
	},
	{
		t: "Respuesta ágil",
		d: "Te contesto dentro de las 24 horas hábiles.",
		icon: "clock",
	},
	{
		t: "Acompañamiento real",
		d: "Te explico cada paso y estoy de principio a fin.",
		icon: "heart",
	},
];
---

<div
	class="reveal mt-16 border-t border-border pt-14 lg:mt-20 lg:pt-20"
	data-reveal
>
	<div class="mx-auto max-w-2xl text-center">
		<p class="text-xs font-medium uppercase tracking-[0.18em] text-calido-4">
			{eyebrow}
		</p>
		<h2
			class="pt-5 text-[clamp(2rem,4.5vw,3rem)] leading-[1.1] text-calido-1 font-serif-ebgaramond"
		>
			{titleTop}<br />
			<em class="text-calido-3">{titleAccent}</em>
		</h2>
		<p
			class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-calido-4 lg:text-lg"
		>
			{text}
		</p>

		<div class="mt-9 flex justify-center">
			<WhatsappButton
				href={buildWhatsappUrl(whatsappMessage)}
				label={whatsappLabel}
			/>
		</div>
	</div>

	<div
		class="mx-auto mt-14 grid max-w-4xl gap-8 border-t border-border pt-12 sm:grid-cols-3 lg:mt-16 lg:gap-12"
	>
		{
			features.map((feature) => (
				<div class="flex flex-col md:flex-row md:items-center md:gap-4">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.4"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="size-12 text-calido-3"
						aria-hidden="true"
					>
						{feature.icon === "shield" && (
							<>
								<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
								<path d="m9 12 2 2 4-4" />
							</>
						)}
						{feature.icon === "clock" && (
							<>
								<circle cx="12" cy="12" r="9" />
								<path d="M12 7v5l3 2" />
							</>
						)}
						{feature.icon === "heart" && (
							<path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z" />
						)}
					</svg>
					<div>
						<p class="mt-4 text-sm font-medium text-calido-1">{feature.t}</p>
					<p class="mt-1.5 text-sm leading-relaxed text-calido-4">
						{feature.d}
					</p>
					</div>
					
				</div>
			))
		}
	</div>
</div>
