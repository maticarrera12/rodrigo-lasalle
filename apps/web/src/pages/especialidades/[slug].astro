---
import "@workspace/ui/globals.css";
import Main from "@/layouts/main.astro";
import { AREAS } from "@/const";
import type { Area } from "@/const";
import CtaConsulta from "@/components/CtaConsulta.astro";

export function getStaticPaths() {
  return AREAS.map((area) => ({
    params: { slug: area.slug },
    props: { area },
  }));
}

interface Props {
  area: Area;
}

const { area } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{area.t} | Rodrigo Lasalle</title>
  </head>
  <body>
    <Main>
      <section class="w-full pt-28 pb-8 lg:pt-32 lg:pb-16">
        <div class="container">
          <div class="reveal mb-12" data-reveal>
            <p class="text-xs font-medium uppercase tracking-[0.14em] text-calido-4">
              — Especialidades / {area.n}
            </p>
            <h1 class="pt-4 text-[clamp(2.25rem,4.5vw,3rem)] leading-tight text-calido-1 font-serif-ebgaramond italic">
              {area.t}
            </h1>
          </div>

          <div class="grid gap-12 lg:grid-cols-[minmax(0,2fr)_minmax(0,3fr)] lg:gap-20">
            <div class="reveal" data-reveal data-reveal-delay={80}>
              <p class="text-base leading-relaxed text-calido-4 lg:text-lg">
                {area.descripcionLarga}
              </p>
              <div class="mt-8">
                <a href="/especialidades" class="back-link group inline-flex items-center gap-1.5 text-sm text-calido-3">
                  <span
                    class="shrink-0 transition-transform duration-300 ease-out group-hover:-translate-x-1"
                    aria-hidden="true"
                  >←</span>
                  <span class="back-link-text relative">Volver a especialidades</span>
                </a>
              </div>
            </div>

            <div class="reveal" data-reveal data-reveal-delay={160}>
              <p class="text-xs font-medium uppercase tracking-[0.14em] text-calido-4 mb-6">
                Servicios incluidos
              </p>
              <ul class="divide-y divide-border border-y border-border">
                {
                  area.servicios.map((servicio) => (
                    <li class="py-3 text-base leading-relaxed text-calido-1 cursor-pointer hover:translate-x-2 transition-all duration-200">
                      {servicio}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>

          <CtaConsulta
            eyebrow="Hablemos de tu caso"
            titleTop="¿Tenés un caso de"
            titleAccent={`${area.t}?`}
            text="Contame tu situación. La primera consulta es para entender qué te pasa y ver si te puedo ayudar."
            whatsappMessage={`Hola, quería consultar sobre ${area.t}.`}
          />
        </div>
      </section>
    </Main>
  </body>
</html>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(1rem);
    transition:
      opacity 0.55s ease,
      transform 0.55s ease;
  }

  .reveal.is-in {
    opacity: 1;
    transform: translateY(0);
  }

  .back-link {
    text-decoration: none;
  }

  .back-link-text::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -3px;
    width: 100%;
    height: 1px;
    background-color: currentColor;
    opacity: 0.55;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .back-link:hover .back-link-text::after {
    transform: scaleX(1);
  }
</style>

<script>
  import { initReveal } from "@/scripts/reveal";

  initReveal();
  document.addEventListener("astro:page-load", initReveal);
</script>
